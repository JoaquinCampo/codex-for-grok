class CodexForGrok < Formula
  desc "Local streaming adapter between Grok Build and a Codex subscription"
  homepage "https://github.com/JoaquinCampo/codex-for-grok"
  version "@VERSION@"
  license "MIT"

  on_macos do
    if Hardware::CPU.arm?
      url "https://github.com/JoaquinCampo/codex-for-grok/releases/download/v@VERSION@/codex-for-grok-@VERSION@-aarch64-apple-darwin.tar.gz"
      sha256 "@SHA_AARCH64_APPLE_DARWIN@"
    else
      url "https://github.com/JoaquinCampo/codex-for-grok/releases/download/v@VERSION@/codex-for-grok-@VERSION@-x86_64-apple-darwin.tar.gz"
      sha256 "@SHA_X86_64_APPLE_DARWIN@"
    end
  end

  on_linux do
    if Hardware::CPU.arm? && Hardware::CPU.is_64_bit?
      url "https://github.com/JoaquinCampo/codex-for-grok/releases/download/v@VERSION@/codex-for-grok-@VERSION@-aarch64-unknown-linux-gnu.tar.gz"
      sha256 "@SHA_AARCH64_UNKNOWN_LINUX_GNU@"
    else
      url "https://github.com/JoaquinCampo/codex-for-grok/releases/download/v@VERSION@/codex-for-grok-@VERSION@-x86_64-unknown-linux-gnu.tar.gz"
      sha256 "@SHA_X86_64_UNKNOWN_LINUX_GNU@"
    end
  end

  def install
    bin.install "codex-for-grok"
  end

  test do
    assert_match version.to_s, shell_output("#{bin}/codex-for-grok --version")
  end
end
